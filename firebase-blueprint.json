{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and gamification stats",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "xp": { "type": "integer" },
        "streak": { "type": "integer" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "lastActive": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "xp", "streak"]
    },
    "Solution": {
      "title": "Doubt Solution",
      "description": "Stored solutions for user doubts",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "query": { "type": "string" },
        "queryType": { "type": "string", "enum": ["text", "image", "voice"] },
        "explanation": { "type": "string" },
        "slides": { "type": "array" },
        "quiz": { "type": "array" },
        "audioUrl": { "type": "string" },
        "topic": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "query", "explanation", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "Individual messages in a tutor conversation",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "tutorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "content", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Main user records"
    },
    "solutions/{solutionId}": {
      "schema": "Solution",
      "description": "Collection of all solved doubts"
    },
    "users/{userId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chat history per user"
    }
  }
}
